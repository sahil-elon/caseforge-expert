% ------------------------------------------------------------
% CaseForge generated SU2 configuration
% Case type: Generic SU2 starter case
% ------------------------------------------------------------

% -------------------------
% Physics
% -------------------------
SOLVER= {{ solver }}
MATH_PROBLEM= DIRECT
RESTART_SOL= NO

% -------------------------
% Mesh
% -------------------------
MESH_FILENAME= {{ mesh_file }}
MESH_FORMAT= SU2

% -------------------------
% Reference values
% Edit these based on your actual case.
% -------------------------
FREESTREAM_PRESSURE= {{ freestream_pressure }}
FREESTREAM_TEMPERATURE= {{ freestream_temperature }}

% -------------------------
% Numerical method
% -------------------------
NUM_METHOD_GRAD= GREEN_GAUSS
CFL_NUMBER= {{ cfl }}
CFL_ADAPT= NO

CONV_NUM_METHOD_FLOW= ROE
MUSCL_FLOW= YES
SLOPE_LIMITER_FLOW= VENKATAKRISHNAN
TIME_DISCRE_FLOW= EULER_IMPLICIT

% -------------------------
% Linear solver
% -------------------------
LINEAR_SOLVER= FGMRES
LINEAR_SOLVER_PREC= ILU
LINEAR_SOLVER_ERROR= 1E-6
LINEAR_SOLVER_ITER= 10

% -------------------------
% Convergence
% -------------------------
EXT_ITER= {{ iterations }}
CONV_RESIDUAL_MINVAL= -8

% -------------------------
% Boundary conditions
% IMPORTANT:
% This is a generic starter section.
% Edit marker names based on your mesh.
% -------------------------

MARKER_EULER= ( {{ wall_marker }} )
MARKER_FAR= ( {{ farfield_marker }} )

MARKER_PLOTTING= ( {{ wall_marker }} )
MARKER_MONITORING= ( {{ wall_marker }} )

% -------------------------
% Output
% -------------------------
SCREEN_OUTPUT= (INNER_ITER, RMS_DENSITY, RMS_MOMENTUM-X, RMS_MOMENTUM-Y, RMS_ENERGY)
HISTORY_OUTPUT= (ITER, RMS_RES)

OUTPUT_FILES= (RESTART, PARAVIEW, SURFACE_PARAVIEW)

VOLUME_FILENAME= flow
SURFACE_FILENAME= surface_flow
RESTART_FILENAME= restart_flow
SOLUTION_FILENAME= solution_flow