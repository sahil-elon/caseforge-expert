% ------------------------------------------------------------
% CaseForge generated SU2 configuration
% Case type: Internal nozzle, inviscid Euler starter case
% ------------------------------------------------------------

SOLVER= EULER
MATH_PROBLEM= DIRECT
RESTART_SOL= NO

KIND_TURB_MODEL= NONE
GAMMA_VALUE= {{ gamma }}
GAS_CONSTANT= {{ gas_constant }}

FREESTREAM_PRESSURE= {{ outlet_pressure }}
FREESTREAM_TEMPERATURE= {{ temperature }}

MESH_FILENAME= {{ mesh_file }}
MESH_FORMAT= SU2

INLET_TYPE= TOTAL_CONDITIONS
MARKER_INLET= ( inlet, {{ temperature }}, {{ inlet_pressure }}, 1.0, 0.0, 0.0 )

MARKER_OUTLET= ( outlet, {{ outlet_pressure }} )

MARKER_EULER= ( wall )

MARKER_SYM= ( symmetry )

MARKER_PLOTTING= ( outlet )
MARKER_MONITORING= ( outlet )

